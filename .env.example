# .env.example — Modèle de configuration Firebase
# Copiez ce fichier en ".env" et remplissez les valeurs.
# NE JAMAIS committer le vrai ".env" dans Git.
#
# ── DÉPLOIEMENT SUR VERCEL ───────────────────────────────────
# Allez dans : Vercel Dashboard → Projet → Settings → Environment Variables
# Ajoutez chacune de ces variables avec sa vraie valeur.
# Sélectionnez les environnements : Production + Preview + Development.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
